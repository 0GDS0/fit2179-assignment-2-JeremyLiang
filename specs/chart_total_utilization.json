{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Macro Utilization: Total Public Transport Network Volume (2018-2026)",
    "fontSize": 16,
    "anchor": "middle",
    "offset": 20
  },
  "width": 750,
  "height": 350,
  "data": {
    "url": "data/monthly_average_patronage_by_day_type_and_by_mode2.csv",
    "format": {"parse": {"Pax_daily": "number"}}
  },
  "transform": [
    {
      "calculate": "datetime(datum.Year, datum.Month - 1, 1)",
      "as": "Date"
    },
    {
      "aggregate": [{"op": "sum", "field": "Pax_daily", "as": "Total_Volume"}],
      "groupby": ["Date"]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {"color": "#2980b9", "size": 3},
        "color": "#3498db",
        "opacity": 0.4,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "Date",
          "type": "temporal",
          "title": "Timeline (Year)",
          "axis": {
            "grid": false, 
            "labelFontSize": 12, 
            "titleFontSize": 13,
            "format": "%Y",
            "tickCount": "year"
          }
        },
        "y": {
          "field": "Total_Volume",
          "type": "quantitative",
          "title": "Total Aggregate Patronage",
          "axis": {"format": ".2s", "grid": true, "labelFontSize": 12, "titleFontSize": 13}
        }
      }
    },
    {
      "mark": {"type": "rule", "color": "#2c3e50", "strokeWidth": 1.5},
      "encoding": {
        "x": {"field": "Date", "type": "temporal"},
        "opacity": {
          "condition": {"param": "hover", "empty": false, "value": 0.5},
          "value": 0
        }
      }
    },
    {
      "mark": {"type": "circle", "color": "#e74c3c", "size": 80},
      "encoding": {
        "x": {"field": "Date", "type": "temporal"},
        "y": {"field": "Total_Volume", "type": "quantitative"},
        "opacity": {
          "condition": {"param": "hover", "empty": false, "value": 1},
          "value": 0
        }
      }
    },
    {
      "params": [{
        "name": "hover",
        "select": {
          "type": "point",
          "fields": ["Date"],
          "nearest": true,
          "on": "mouseover",
          "clear": "mouseout"
        }
      }],
      "mark": {
        "type": "rule", 
        "strokeWidth": 10, 
        "color": "transparent", 
        "cursor": "pointer"
      },
      "encoding": {
        "x": {"field": "Date", "type": "temporal"},
        "tooltip": [
          {"field": "Date", "type": "temporal", "timeUnit": "yearmonth", "title": "Month"},
          {"field": "Total_Volume", "type": "quantitative", "title": "Total Volume", "format": ",.0f"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"date": "2018-08-26", "event": "Mernda Extension"},
          {"date": "2021-01-30", "event": "Ballarat Line Upgrade"},
          {"date": "2025-06-01", "event": "Metro Tunnel Testing/Opens"}
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#e74c3c",
        "strokeWidth": 2,
        "strokeDash": [4, 4],
        "opacity": 0.8
      },
      "encoding": {
        "x": {"field": "date", "type": "temporal"}
      }
    },
    {
      "data": {
        "values": [
          {"date": "2018-08-26", "event": "Mernda Extension", "y_pos": 21000000},
          {"date": "2021-01-30", "event": "Ballarat Upgrade", "y_pos": 13000000},
          {"date": "2025-06-01", "event": "Metro Tunnel", "y_pos": 21000000}
        ]
      },
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 6,
        "dy": -4,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#e74c3c"
      },
      "encoding": {
        "x": {"field": "date", "type": "temporal"},
        "y": {"field": "y_pos", "type": "quantitative"},
        "text": {"field": "event", "type": "nominal"}
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"}
  }
}